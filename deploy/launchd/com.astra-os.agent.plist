<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.astra-os.agent</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>/opt/astra-os/dist/index.js</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/opt/astra-os</string>

  <!-- Start on boot -->
  <key>RunAtLoad</key>
  <true/>

  <!-- Auto-restart on crash -->
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>

  <!-- Restart throttle (seconds) -->
  <key>ThrottleInterval</key>
  <integer>5</integer>

  <!-- Logging -->
  <key>StandardOutPath</key>
  <string>/var/log/astra-os/astra-os.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/var/log/astra-os/astra-os.stderr.log</string>

  <!-- Environment variables -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>NODE_ENV</key>
    <string>production</string>
    <key>LOG_FORMAT</key>
    <string>json</string>
    <key>PORT</key>
    <string>3000</string>
  </dict>

  <!-- Resource limits -->
  <key>SoftResourceLimits</key>
  <dict>
    <key>NumberOfFiles</key>
    <integer>65536</integer>
  </dict>

  <key>HardResourceLimits</key>
  <dict>
    <key>NumberOfFiles</key>
    <integer>65536</integer>
  </dict>

  <!-- Process type -->
  <key>ProcessType</key>
  <string>Standard</string>

  <!-- Nice priority (0 = normal) -->
  <key>Nice</key>
  <integer>0</integer>
</dict>
</plist>
