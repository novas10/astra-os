# AstraOS v3.5 Environment Configuration
# Copy this file to .env and fill in your values

# ══════════════════════════════════════
# LLM Providers (at least one required)
# ══════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=claude-sonnet-4-20250514

# ══════════════════════════════════════
# Security (REQUIRED for production)
# ══════════════════════════════════════
ASTRA_API_KEYS=key1,key2,key3
MASTER_ENCRYPTION_KEY=your-32-byte-hex-key
JWT_SECRET=your-jwt-secret

# ══════════════════════════════════════
# Channel Integrations (all optional)
# ══════════════════════════════════════

# Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp (Meta Business API)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=

# Discord
DISCORD_APP_ID=
DISCORD_BOT_TOKEN=

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# Microsoft Teams
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# Signal
SIGNAL_PHONE_NUMBER=
SIGNAL_CLI_REST_URL=http://localhost:8080

# Matrix
MATRIX_HOMESERVER_URL=https://matrix.org
MATRIX_ACCESS_TOKEN=
MATRIX_USER_ID=@bot:matrix.org

# Google Chat
GOOGLE_CHAT_SERVICE_ACCOUNT=
GOOGLE_CHAT_TOKEN=

# iMessage (BlueBubbles)
BLUEBUBBLES_SERVER_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=

# Zalo (Vietnam)
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_ACCESS_TOKEN=

# Phone (Telnyx Programmable Voice)
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_PHONE_NUMBER=+1...

# WebChat
WEBCHAT_PORT=18790
WEBCHAT_TITLE=AstraOS Chat
WEBCHAT_PRIMARY_COLOR=#6366f1

# ══════════════════════════════════════
# Voice (ElevenLabs TTS + Whisper STT)
# ══════════════════════════════════════
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
DEEPGRAM_API_KEY=
STT_API_KEY=

# ══════════════════════════════════════
# Enterprise SSO
# ══════════════════════════════════════
# SSO_SAML_ENTRY_POINT=https://idp.example.com/sso
# SSO_SAML_ISSUER=astra-os
# SSO_SAML_CERT=
# SSO_OIDC_ISSUER=https://accounts.google.com
# SSO_OIDC_CLIENT_ID=
# SSO_OIDC_CLIENT_SECRET=

# ══════════════════════════════════════
# Billing (Stripe)
# ══════════════════════════════════════
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_TEAM_PRICE_ID=price_...
# STRIPE_ENTERPRISE_PRICE_ID=price_...

# ══════════════════════════════════════
# Server
# ══════════════════════════════════════
PORT=3000
CANVAS_PORT=18793
NODE_ENV=development
MEMORY_DIR=.astra-memory
WORKSPACE_DIR=workspace
ASTRA_HUB_URL=https://hub.astra-os.dev/api/v1

# ══════════════════════════════════════
# Vector DB (Optional)
# ══════════════════════════════════════
# VOYAGE_API_KEY=
# QDRANT_URL=
# QDRANT_API_KEY=

# ══════════════════════════════════════
# Observability (OpenTelemetry)
# ══════════════════════════════════════
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=astra-os
